# Homer — environment variables template
#
# Copy to secrets/.env, fill in real values, then:  chmod 600 secrets/.env
# NEVER commit secrets/.env to git.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=                    # aistudio.google.com → Get API key (free tier)
# Optional — when set, voice notes (WhatsApp/Telegram) get transcribed via
# Whisper-large-v3. Without a key, voice messages arrive as
# "[Voice Message: Transcription failed]". Get one at console.groq.com.
GROQ_API_KEY=

# ── Model routing ─────────────────────────────────────────────────────────────
HOMER_DEFAULT_MODEL=gemini/gemini-3.1-pro-preview
HOMER_DEFAULT_PROVIDER=gemini
HOMER_REASONING_MODEL=gemini/gemini-3.1-pro-preview
HOMER_REASONING_PROVIDER=gemini
# To use Claude Sonnet for reasoning instead:
# HOMER_REASONING_MODEL=claude-sonnet-4-6
# HOMER_REASONING_PROVIDER=anthropic
# Guest agent model — pro is required for the family-historian skill to follow
# its prescribed tool sequence reliably.
HOMER_GUEST_MODEL=gemini/gemini-3.1-pro-preview
HOMER_GUEST_PROVIDER=gemini

# ── Telegram channel ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # @BotFather → /newbot (prod)
TELEGRAM_BOT_TOKEN_DEV=            # @BotFather → /newbot (separate dev bot, optional)
# Per-household-member Telegram IDs. Get each ID via @userinfobot → /start.
# These wire into config/config.json.template's Telegram `allowFrom` allowlist.
PRIMARY_TELEGRAM_ID=
SECONDARY_TELEGRAM_ID=              # optional — leave blank to disable

# ── WhatsApp channel ──────────────────────────────────────────────────────────
# WhatsApp runs in-process via neonize (whatsmeow Go bindings); no separate
# bridge process. Set HOMER_WHATSAPP_ENABLED=true to turn it on.
HOMER_WHATSAPP_ENABLED=            # true / false (or empty to default off)
# Per-household-member WhatsApp numbers — digits only, no '+'.
PRIMARY_WHATSAPP=
SECONDARY_WHATSAPP=                 # optional — leave blank to disable

# ── Email sending ─────────────────────────────────────────────────────────────
HOMER_EMAIL_ADDRESS=               # the address Homer sends from, e.g. homer@yourdomain
HOMER_EMAIL_DISPLAY_NAME=Homer (AI Assistant)
# Comma-separated addresses or @domain patterns for the direct-send guard.
# 'send' rejects recipients not matching these patterns.
# Use 'draft' + 'draft-send' for external recipients (human-in-the-loop).
HOMER_INTERNAL_EMAILS=             # e.g. user@gmail.com,@yourdomain
HOMER_EMAIL_APPROVALS_DB=          # default: context/.nanobot_workspace/state/email_approvals.db

# ── Google OAuth (web client — portal link-account flow) ──────────────────────
# Create a "Web application" OAuth client in GCP Console → APIs & Services → Credentials
# and register the redirect URI below. For local dev the loopback URL works.
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/accounts/oauth/callback

# ── Google APIs (Gmail + Calendar + Drive + Docs + Sheets) ────────────────────
# credentials.json: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client
# Run: python tools/google_auth.py to generate token
GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_TOKEN_FILE=secrets/google_token.pickle
# Optional: Google Doc with tabs to pull context from (sync_from_drive.py)
HOMER_CONTEXT_DOC_ID=
# Optional: shared Drive folder for export_context.py / drive_upload.py
# Get ID from drive.google.com/drive/folders/<ID>
HOMER_EXPORT_FOLDER_ID=
# Optional: private Drive folder for nightly context backups (backup_context.py)
HOMER_BACKUP_FOLDER_ID=

# ── Plaid (balance + transactions) ────────────────────────────────────────────
# dashboard.plaid.com → Team Settings → Keys
# Per institution, run: python tools/plaid_link.py --institution <name>
# Access tokens get written back into this .env as PLAID_ACCESS_TOKEN_<NAME>.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                  # sandbox | development | production

# ── Tavily (web search, research, extract) ────────────────────────────────────
# app.tavily.com → API Keys (free tier: 1,000 calls/month)
TAVILY_API_KEY=

# ── Google Maps (places + distance) ───────────────────────────────────────────
# GCP Console → APIs & Services → Credentials → Create API Key
# Enable: Places API, Distance Matrix API
GOOGLE_MAPS_API_KEY=

# ── Voice transcription ───────────────────────────────────────────────────────
# Used by nanobot to transcribe incoming voice messages before passing to Homer.
# GEMINI_API_KEY (above) is reused; no separate key needed.
VOICE_TRANSCRIPTION_PROVIDER=gemini   # gemini | claude | disabled
VOICE_TRANSCRIPTION_MODEL=gemini-2.5-flash

# ── Skyvern (browser automation — tickets, forms, web tasks) ──────────────────
# app.skyvern.com → Settings → API Keys ($5 free credits to start)
SKYVERN_API_KEY=
# Optional webhook callback URL — leave blank to skip
SKYVERN_WEBHOOK_URL=

# ── Web Portal ────────────────────────────────────────────────────────────────
# Optional self-host portal. Generate JWT secret with: openssl rand -hex 32
PORTAL_DOMAIN=
PORTAL_BASE_URL=http://localhost:8000
PORTAL_JWT_SECRET=

# ── PostHog analytics (optional) ──────────────────────────────────────────────
# us.posthog.com → Project Settings → API Key
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Feedback channel (optional) ───────────────────────────────────────────────
# GitHub PAT with `issues:write` scope only — used by tools/feedback_submit.py
# to file user-submitted feedback as GitHub issues.
HOMER_FEEDBACK_TOKEN=
HOMER_FEEDBACK_REPO=               # owner/repo

# ── Family History (optional — Supabase) ──────────────────────────────────────
# Supabase Console → Project Settings → API
SUPABASE_URL=                      # https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=              # service_role key — bypasses RLS, keep secret
HOMER_HISTORY_BASE_URL=            # public timeline URL (e.g. https://history.<your-domain>)

# ── Timezone + paths ──────────────────────────────────────────────────────────
HOMER_TIMEZONE=America/New_York    # IANA timezone for heartbeat scheduling
HOMER_HOME=                        # absolute path to homer repo (auto-detected if blank)
HOMER_WORKSPACE=                   # nanobot workspace path (auto if blank)
HOMER_SECRETS=                     # OAuth token directory (auto if blank)
